// 测试错误处理: 第1行的J指令跳转到不存在四元式行99
// 期望: 解释器应报错或达到步数限制
0: (=, 10, _, a)
1: (J, _, _, 99)
2: (write, a, _, _)
3: (return, a, _, _)

--- [4.2 输出] LLVM IR 代码 ---
declare i32 @printf(ptr, ...)

@.fmt_num = private constant [3 x i8] c"%d\00"
@.fmt_chr = private constant [3 x i8] c"%c\00"


define i32 @main() {
entry:
  %a_ptr = alloca i32
  br label %block0

block0:
  store i32 10, ptr %a_ptr
  br label %block0

block1:
  %rt0 = load i32, ptr %a_ptr
  call i32 (ptr, ...) @printf(ptr @.fmt_num, i32 %rt0)
  %rt1 = load i32, ptr %a_ptr
  ret i32 %rt1

}

